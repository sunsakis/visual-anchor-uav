<?xml version="1.0"?>
<model>
  <name>3DR Iris with lidar, optical flow, and anchor camera</name>
  <version>1.0</version>
  <sdf version='1.4'>iris_opt_flow.sdf</sdf>

  <description>
    Local override of PX4's stock iris_opt_flow model. Adds a second
    downward-facing camera (anchor_cam_iris, 1280x800 @ 110° HFOV, Arducam
    OV9281 + wide M12 NoIR bundle specs) alongside the existing px4flow
    narrow-FOV flow sensor and lidar. The anchor camera is observation-only
    (publishes /anchor_cam/image_raw + /camera_info); px4flow continues to
    drive PX4's EKF2 flow fusion unchanged.
  </description>
</model>
