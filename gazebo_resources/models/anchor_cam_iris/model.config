<?xml version="1.0"?>
<model>
  <name>Anchor cam (dynamic, drone-mounted)</name>
  <version>1.0</version>
  <sdf version='1.5'>anchor_cam_iris.sdf</sdf>
  <description>
    Downward-facing wide-lens mono camera for the anchor-path estimator.
    Specs match the Arducam OV9281 + wide M12 bundle (Botland sku 16886):
    1280x800 mono global shutter, 110 deg H-FOV. Unlike gazebo_resources/
    models/anchor_cam (static bench rig), this model is NOT static so it
    moves with the drone it's joint-mounted to.
  </description>
</model>
