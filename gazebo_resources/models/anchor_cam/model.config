<?xml version="1.0"?>
<model>
  <name>anchor_cam</name>
  <version>1.0</version>
  <sdf version="1.5">anchor_cam.sdf</sdf>
  <description>
    Static downward-facing camera for anchor-matching bench. SDF is
    rewritten between sweep cells to change resolution / HFOV; only
    the &lt;camera&gt; block changes.
  </description>
</model>
